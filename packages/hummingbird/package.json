{
  "name": "@tuomashatakka/hummingbird-design-system",
  "version": "0.2.3",
  "description": "A monochrome, semantic-HTML design system — customizable oklch tokens, native elements, zero utility classes. Ships React components and the raw CSS.",
  "keywords": [
    "design-system",
    "react",
    "css",
    "components",
    "semantic-html",
    "oklch",
    "monochrome",
    "hummingbird"
  ],
  "license": "MIT",
  "author": "Tuomas Hatakka",
  "repository": {
    "type": "git",
    "url": "https://github.com/tuomashatakka/hummingbird-design-system.git",
    "directory": "packages/hummingbird"
  },
  "homepage": "https://github.com/tuomashatakka/hummingbird-design-system#readme",
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "files": [
    "dist",
    "styles"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./state": {
      "types": "./dist/state.d.ts",
      "import": "./dist/state.js"
    },
    "./styles.css": "./styles/index.css",
    "./tokens.css": "./styles/tokens.css",
    "./base.css": "./styles/base.css",
    "./components.css": "./styles/components.css",
    "./fonts/*": "./styles/fonts/*",
    "./package.json": "./package.json"
  },
  "scripts": {
    "build": "bunchee",
    "dev": "bunchee --watch",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "bunchee": "^6.11.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
