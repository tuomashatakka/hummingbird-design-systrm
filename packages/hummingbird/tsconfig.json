{
  "compilerOptions": {
    "target": "ES2022",
    "lib": [ "dom", "dom.iterable", "esnext" ],
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "verbatimModuleSyntax": true,
    "jsx": "react-jsx",
    "declaration": true,
    "paths": {
      "@/*": [ "./src/*" ]
    }
  },
  "include": [ "src/**/*.ts", "src/**/*.tsx" ],
  "exclude": [ "node_modules", "dist" ]
}
